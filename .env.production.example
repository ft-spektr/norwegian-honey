# Production .env for Hetzner VPS
# Copy to .env on the server: cp .env.production.example .env

APP_NAME=norwegian-honey
DEBUG=false
TRUSTED_PROXY_HEADERS=true

# Your public hostname (must match DNS + Caddy DOMAIN)
DOMAIN=canary.example.com
PUBLIC_BASE_URL=https://canary.example.com

# Required — protects investigative endpoints from counter-attack abuse
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
INVESTIGATOR_API_KEY=

# OSINT API keys (optional)
ABUSEIPDB_API_KEY=
IPINFO_API_KEY=

OSINT_CACHE_TTL=3600

CANARY_STORAGE=sqlite
CANARY_SQLITE_PATH=/data/canary.db
CANARY_REQUIRE_REGISTERED_TOKEN=true
CANARY_HIT_RETENTION_DAYS=90

INFLUX_URL=http://influxdb:8086
INFLUX_TOKEN=
INFLUX_ORG=norwegian-honey
INFLUX_BUCKET=canary
