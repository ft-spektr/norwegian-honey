# Production .env for Hetzner VPS
# Copy to .env on the server: cp .env.production.example .env

APP_NAME=norwegian-honey
DEBUG=false
TRUSTED_PROXY_HEADERS=true

# Your public hostname (must match DNS A record)
DOMAIN=www736.your-server.de
PUBLIC_BASE_URL=https://www736.your-server.de

# OSINT API keys (optional)
ABUSEIPDB_API_KEY=
IPINFO_API_KEY=

OSINT_CACHE_TTL=3600

CANARY_STORAGE=sqlite
CANARY_SQLITE_PATH=/data/canary.db

INFLUX_URL=http://influxdb:8086
INFLUX_TOKEN=
INFLUX_ORG=norwegian-honey
INFLUX_BUCKET=canary
