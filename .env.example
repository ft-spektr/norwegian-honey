# Application
APP_NAME=norwegian-honey
DEBUG=false
TRUSTED_PROXY_HEADERS=true
# Keep true when behind ngrok/reverse proxy so canary logs capture real client IPs

# OSINT API keys (optional — modules degrade gracefully without them)
ABUSEIPDB_API_KEY=
IPINFO_API_KEY=

# Cache TTL for OSINT lookups (seconds)
OSINT_CACHE_TTL=3600

# Canary storage: sqlite | influx
CANARY_STORAGE=sqlite
# Use ./data for local dev; /data/canary.db in Docker (see docker-compose.yml)
CANARY_SQLITE_PATH=./data/canary.db

# InfluxDB (only if CANARY_STORAGE=influx)
INFLUX_URL=http://influxdb:8086
INFLUX_TOKEN=
INFLUX_ORG=norwegian-honey
INFLUX_BUCKET=canary

# Public URL for canary embeds — must match domain in ngrok.yml
PUBLIC_BASE_URL=https://unmoral-headpiece-subside.ngrok-free.dev

# ngrok authtoken (optional if using ngrok.local.yml instead)
# NGROK_AUTHTOKEN=