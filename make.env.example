# Client-side Makefile config — copy to make.env and edit.
# Used when running make from your laptop against the cloud deployment.

# Production API base URL (no trailing slash)
DOMAIN=spek-tr.no
PROD_URL=https://$(DOMAIN)

# SSH access for remote canary logs (from your laptop)
# Use key auth — add ~/.ssh/norwegian-honey.pub to the server's authorized_keys
PROD_SSH=root@YOUR_VPS_IP
PROD_SSH_KEY=$(HOME)/.ssh/norwegian-honey
PROD_SSH_PORT=22
PROD_REMOTE_DIR=/opt/norwegian-honey
